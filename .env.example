# Variáveis de ambiente da Allana (chatbot)
# Copie para .env (local) e configure no painel da Vercel (produção).
# NUNCA commitar a .env real — já está no .gitignore.

# ── Backend (somente servidor; nunca exposto ao frontend) ──
# Chave da OpenRouter. Crie chaves separadas para dev e prod no painel da OpenRouter.
OPENROUTER_API_KEY=

# Domínio oficial do site (para CORS). Ex.: https://aracagrill.com
ALLOWED_ORIGIN=

# Modelos (opcional — já têm default no código)
MODEL_PRIMARY=google/gemini-2.5-flash-lite
MODEL_FALLBACK=google/gemini-2.5-flash

# ── Frontend (Vite — precisa do prefixo VITE_, embutido no build) ──
# URL do cardápio usada pelo botão "Ver cardápio" da Allana.
VITE_MENU_URL=
